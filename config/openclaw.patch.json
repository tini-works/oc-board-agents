{
  "_comment": "This patch is applied to ~/.openclaw/openclaw.json by install.sh",
  "agents": {
    "defaults": {
      "memorySearch": {
        "enabled": true,
        "provider": "local",
        "fallback": "none",
        "local": {
          "modelPath": "hf:ggml-org/embeddinggemma-300M-GGUF/embeddinggemma-300M-Q8_0.gguf"
        },
        "extraPaths": [
          "MEMORY.md",
          "SOUL.md",
          "USER.md",
          "TOOLS.md",
          "AGENTS.md",
          "skills"
        ]
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "workspace": "{{OPENCLAW_HOME}}/workspace",
        "tools": {
          "allow": ["read", "write", "exec", "web_search", "web_fetch", "memory_search"]
        }
      },
      {
        "id": "board",
        "workspace": "{{OPENCLAW_HOME}}/workspace/agents/board",
        "tools": {
          "allow": ["read", "web_search", "web_fetch", "memory_search"]
        }
      },
      {
        "id": "sot-scribe",
        "workspace": "{{OPENCLAW_HOME}}/workspace/agents/sot-scribe",
        "tools": {
          "allow": ["read", "write", "exec", "web_search", "web_fetch", "memory_search"]
        }
      },
      {
        "id": "sot-editor",
        "workspace": "{{OPENCLAW_HOME}}/workspace/agents/sot-editor",
        "tools": {
          "allow": ["read", "write", "exec", "memory_search"]
        }
      },
      {
        "id": "sot-reader",
        "workspace": "{{OPENCLAW_HOME}}/workspace/agents/sot-reader",
        "tools": {
          "allow": ["read", "memory_search"]
        }
      }
    ]
  },
  "gateway": {
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    },
    "tools": {
      "allow": [
        "sessions_send"
      ]
    }
  }
}
